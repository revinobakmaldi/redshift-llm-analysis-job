# Redshift
REDSHIFT_HOST=your-redshift-cluster.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=analytics
REDSHIFT_USER=your_user
REDSHIFT_PASSWORD=your_password
REDSHIFT_SCHEMA=public

# Source query
SOURCE_SQL_PATH=sql/source_query.sql
SOURCE_NAME=daily_sales_kpi_snapshot
SOURCE_PREVIEW_ROWS=200

# Writeback target
TARGET_TABLE=llm_analysis_results
JOB_NAME=redshift_llm_analysis_job

# LM Studio
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=gpt-oss-20b
LLM_API_KEY=lm-studio
LLM_TIMEOUT_SECONDS=180
LLM_MAX_TOKENS=1600
LLM_TEMPERATURE=0.2
LLM_SYSTEM_PROMPT_PATH=prompts/system_prompt.txt

# Logging
LOG_LEVEL=INFO
